        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% Main Header\n    Sub[SUBORDINATE CLAUSE]\n    \n    %% First Level\n    Sub --- Noun[Noun Clause]\n    Sub --- Adj[Adjective Clause]\n    Sub --- Adv[Adverbial Clause]\n\n    %% Functional Descriptions\n    Noun --- N_Desc[\&quot;(Acts as Noun)\&quot;]\n    Adj --- Adj_Desc[\&quot;(Describes Noun)\&quot;]\n    Adv --- Adv_Desc[\&quot;(Modifies Verb / Adjective / Sentence)\&quot;]\n\n    %% Noun Clause Branches\n    N_Desc --- Subject[Subject]\n    N_Desc --- Object[Object / Complement]\n\n    %% Adjective Clause Branches\n    Adj_Desc --- Who[Who / Which Clause]\n    Adj_Desc --- That[That Clause]\n\n    %% Adverbial Clause Branches\n    Adv_Desc --- Time[Time: When]\n    Adv_Desc --- Place[Place: Where]\n    Adv_Desc --- Cond[Condition: If, Unless, Though]\n    Adv_Desc --- Reason[Reason: Because, Since, So that, etc.]\n\n    %% Styling for better visualization in draw.io\n    style Sub fill:#f9f,stroke:#333,stroke-width:2px\n    style Noun fill:#e1f5fe,stroke:#01579b\n    style Adj fill:#e8f5e9,stroke:#1b5e20\n    style Adv fill:#fff3e0,stroke:#e65100&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="5QTPZC6a6JeYhNMM7wbX-42">
